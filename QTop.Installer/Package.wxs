<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="QTop"
    Manufacturer="Code-iX"
    Version="$(var.ProductVersion)"
    UpgradeCode="{E47B06A8-62A2-41C9-AF4E-63868838B589}"
    Language="1033"
    Scope="perMachine">

    <SummaryInformation Description="QTop Installer" Manufacturer="Code-iX" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of QTop is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="QTopIcon" SourceFile="..\QTop\Assets\qtop.ico" />
    <Property Id="ARPPRODUCTICON" Value="QTopIcon" />
    <Property Id="ARPCOMMENTS" Value="Elevated Windows process manager. Requires administrator rights when launched." />
    <Property Id="ARPHELPLINK" Value="https://github.com/Matt-17/QTop/issues" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Matt-17/QTop" />

    <Feature Id="MainFeature" Title="QTop" Level="1">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="QTop" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="{676A35BA-E0AE-467C-8C53-7A9E0E033DD1}">
        <File Id="QTopExe" Source="$(var.PublishDir)\QTop.exe" />
        <File Id="D3DCompiler47" Source="$(var.PublishDir)\D3DCompiler_47_cor3.dll" />
        <File Id="PenImc" Source="$(var.PublishDir)\PenImc_cor3.dll" />
        <File Id="PresentationNative" Source="$(var.PublishDir)\PresentationNative_cor3.dll" />
        <File Id="Vcruntime140" Source="$(var.PublishDir)\vcruntime140_cor3.dll" />
        <File Id="WpfGfx" Source="$(var.PublishDir)\wpfgfx_cor3.dll" />
        <RegistryValue Root="HKLM" Key="Software\Code-iX\QTop" Name="InstallFolder" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
      </Component>

      <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder" Guid="{9303D4F5-797F-4D28-BB48-DB0ED03D2F76}">
        <Shortcut
          Id="AppShortcut"
          Name="QTop"
          Description="Elevated Windows process manager"
          Target="[INSTALLFOLDER]QTop.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="QTopIcon" />
        <RegistryValue Root="HKCU" Key="Software\Code-iX\QTop" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
