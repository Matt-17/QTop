<Window x:Class="QTop.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About QTop"
        Width="520"
        Height="500"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBrush}">
    <Window.Resources>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,6,0,1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Width="64" Height="64" CornerRadius="12" Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                <TextBlock Text="QT" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="QTop" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="Elevated Windows process manager" Style="{StaticResource Hint}" Margin="0,2,0,0" />
                <TextBlock Text="Code-iX" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="About" Style="{StaticResource SectionTitle}" Margin="0,0,0,6" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource Hint}"
                           Text="QTop lists Windows processes with elevated detail access, grouped categories, service enrichment, filtering, and confirmation-based process termination." />

                <TextBlock Text="Included" Style="{StaticResource SectionTitle}" Margin="0,18,0,0" />
                <TextBlock Margin="0,8,0,0" Style="{StaticResource Hint}" Text="Grouped process grid, protected/system filtering, process details, service names, executable metadata, process icons, refresh cadence, graceful close for apps, and force kill reporting." />

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Author" Style="{StaticResource DetailLabel}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Matthias Voigt" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Company" Style="{StaticResource DetailLabel}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Code-iX" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Copyright" Style="{StaticResource DetailLabel}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Copyright (c) 2026 Matthias Voigt" Style="{StaticResource DetailValue}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="GitHub" Style="{StaticResource DetailLabel}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValue}">
                        <Hyperlink NavigateUri="https://github.com/Matt-17/QTop"
                                   RequestNavigate="GitHubLink_RequestNavigate"
                                   TextDecorations="None">
                            https://github.com/Matt-17/QTop
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>

        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Style="{StaticResource PrimaryButton}"
                IsCancel="True"
                Click="Close_Click" />
    </Grid>
</Window>
